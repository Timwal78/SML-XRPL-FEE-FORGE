# =============================================================================
# SML XRPL FEE FORGE — environment configuration
# =============================================================================
# Copy this file to .env and fill in. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# XRPL network selection
# -----------------------------------------------------------------------------
# testnet | mainnet
XRPL_NETWORK=testnet

# WebSocket endpoints (auto-selected from XRPL_NETWORK; override only if needed)
XRPL_WS_MAINNET=wss://xrplcluster.com
XRPL_WS_TESTNET=wss://s.altnet.rippletest.net:51233

# JSON-RPC endpoints
XRPL_RPC_MAINNET=https://xrplcluster.com
XRPL_RPC_TESTNET=https://s.altnet.rippletest.net:51234

# -----------------------------------------------------------------------------
# RLUSD constants (DO NOT MODIFY — verified against xrpscan.com 2026-05-09)
# -----------------------------------------------------------------------------
RLUSD_ISSUER_MAINNET=rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De
RLUSD_ISSUER_TESTNET=rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV
RLUSD_CURRENCY_HEX=524C555344000000000000000000000000000000

# -----------------------------------------------------------------------------
# Operator wallet (run scripts/init_testnet_wallet.py to populate for testnet)
# -----------------------------------------------------------------------------
# Hot wallet — receives invoices, sends fees and forwards
OPERATOR_WALLET_SEED=
OPERATOR_WALLET_ADDRESS=

# Fee wallet — receives the 0.5% skim (can equal operator wallet)
FEE_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# Fee configuration (basis points)
# -----------------------------------------------------------------------------
RAILS_FEE_BPS=50          # 0.50%

# -----------------------------------------------------------------------------
# Anthropic API (RLUSD Rails copywriter + gateway BYOK)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_COPY_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Discord alerts
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_RAILS=
# Cross-product payment feed
DISCORD_WEBHOOK_PAYMENTS=
DISCORD_WEBHOOK_ALL=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
RAILS_DB_URL=sqlite:///./rails.db

# -----------------------------------------------------------------------------
# Service ports (local dev)
# -----------------------------------------------------------------------------
RAILS_PORT=8002

# -----------------------------------------------------------------------------
# Widget / CORS
# -----------------------------------------------------------------------------
RAILS_ALLOWED_ORIGINS=*
RAILS_PUBLIC_URL=http://localhost:8002

# =============================================================================
# FORGE GATEWAY (x402 payment middleware — Go service)
# See x402-gateway/.env.example for full gateway config.
# Key vars needed for Render deploy:
# =============================================================================

# EVM wallet on Base that receives USDC payments
MERCHANT_WALLET_ADDRESS=0x

# Price per inference request (USDC micro-units, 6 decimals: 500000 = $0.50)
PAYMENT_AMOUNT_USDC_DROPS=500000

# XRPL wallet for Ghost Layer notary memos
XRPL_NOTARY_WALLET_ADDRESS=
XRPL_NOTARY_WALLET_SEED=

# Redis URL for rate limiting (auto-wired from forge-redis on Render)
REDIS_URL=redis://localhost:6379

# AI provider keys injected by BYOK engine (never exposed to agents)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Operator metadata
# -----------------------------------------------------------------------------
OPERATOR_BRAND=ScriptMasterLabs
OPERATOR_TIMEZONE=America/New_York
