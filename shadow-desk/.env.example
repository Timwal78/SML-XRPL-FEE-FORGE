# Shadow Desk x402 Gateway — Environment Configuration
# Copy to .env and fill in values before running.

# Server listen port
PORT=8080

# TradingView Pine Script webhook authentication secret.
# Must match the secret_key field in every alert payload.
INGEST_SECRET=change-me-super-secret

# On-chain wallet address receiving 99% of x402 USDC micropayments (Base mainnet, 0x format)
ALPHA_PROVIDER_WALLET=0x0000000000000000000000000000000000000000

# Platform fee wallet receiving 1% of all settled micropayments
PLATFORM_WALLET=0x0000000000000000000000000000000000000000

# x402 payment facilitator endpoint used to verify on-chain settlement proofs.
# Default is the public x402.org facilitator. Swap for your own or 402proof.onrender.com.
FACILITATOR_URL=https://x402.org/facilitator

# Admin API key protecting GET /v1/admin/billing
ADMIN_API_KEY=change-me-admin-key
