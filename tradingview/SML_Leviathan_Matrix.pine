// SML Leviathan Matrix — TradingView Pine Script v6
// Fires alerts to Shadow Desk + Signal API simultaneously.
// BEASTMODE: real dual-alert system per BEASTMODE.md rule 8.
// Copy this script into TradingView Pine Editor and add to chart.

//@version=6
indicator("SML Leviathan Matrix Alerts", shorttitle="SML-LMX", overlay=true)

// ═══════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════
grp = "SML Leviathan Matrix"
rvolThresh  = input.float(1.5,  "RVOL Threshold (Breakout)",   minval=1.0, step=0.1, group=grp)
rvolSqz     = input.float(0.8,  "RVOL Threshold (Squeeze)",    minval=0.1, step=0.1, group=grp)
atrMult     = input.float(1.5,  "ATR Multiplier (Range)",      minval=0.5, step=0.1, group=grp)
lookback    = input.int(20,     "Lookback Period",             minval=5,   step=1,   group=grp)

// ═══════════════════════════════════════════════════════
// CORE CALCULATIONS
// ═══════════════════════════════════════════════════════
// Relative Volume
avgVol  = ta.sma(volume, lookback)
rvol    = volume / avgVol

// ATR-based range compression (squeeze detection)
atr     = ta.atr(14)
hlRange = high - low
compressed = hlRange < (atr * atrMult)

// Momentum
rsi     = ta.rsi(close, 14)
ema20   = ta.ema(close, 20)
ema50   = ta.ema(close, 50)

// Regime: Bull = price > EMA20 > EMA50
bullRegime  = close > ema20 and ema20 > ema50
bearRegime  = close < ema20 and ema20 < ema50

// ═══════════════════════════════════════════════════════
// SIGNAL CONDITIONS
// ═══════════════════════════════════════════════════════
// EXECUTE_LONG: volume breakout + bull regime + momentum
longCond = rvol >= rvolThresh and bullRegime and rsi > 55 and ta.crossover(close, ema20)

// EXECUTE_SHORT: squeeze detected + bear regime + momentum fading
shortCond = rvol >= rvolThresh and bearRegime and rsi < 45 and ta.crossunder(close, ema20)

// SQUEEZE: low RVOL compression — coiled spring
squeezeCond = rvol <= rvolSqz and compressed and not (longCond or shortCond)

// ═══════════════════════════════════════════════════════
// VISUALS (BEASTMODE colors: neon green, hot pink, gold)
// ═══════════════════════════════════════════════════════
plotshape(longCond,   title="LONG",    style=shape.triangleup,   location=location.belowbar, color=#00FF41, size=size.normal, text="LONG")
plotshape(shortCond,  title="SHORT",   style=shape.triangledown, location=location.abovebar, color=#FF006E, size=size.normal, text="SHORT")
plotshape(squeezeCond, title="SQUEEZE", style=shape.circle,      location=location.belowbar, color=#FFD700, size=size.small,  text="SQZ")

plot(ema20, title="EMA 20", color=#00FF41, linewidth=1)
plot(ema50, title="EMA 50", color=#FF006E, linewidth=1, style=plot.style_circles)

// ═══════════════════════════════════════════════════════
// DUAL ALERT SYSTEM
// Webhook #1: Shadow Desk (per-call x402 micropayment rail)
//   URL: https://shadow-desk.onrender.com/v1/ingest
//   Header: X-Ingest-Secret: sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802
//
// Webhook #2: Signal API (Leviathan Matrix + Discord broadcast)
//   URL: https://sml-x402-signal-api.onrender.com/api/tv/equities/webhook
//   Header: x-webhook-secret: test_secret
// ═══════════════════════════════════════════════════════

// alertcondition for manual alert setup in TV Alert dialog
alertcondition(longCond,    title="SML LONG Signal",    message='{"ticker":"{{ticker}}","action":"EXECUTE_LONG","close":"{{close}}","volume":"{{volume}}","system":"SML_Leviathan","timeframe":"{{interval}}","secret_key":"sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802"}')
alertcondition(shortCond,   title="SML SHORT Signal",   message='{"ticker":"{{ticker}}","action":"EXECUTE_SHORT","close":"{{close}}","volume":"{{volume}}","system":"SML_Leviathan","timeframe":"{{interval}}","secret_key":"sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802"}')
alertcondition(squeezeCond, title="SML SQUEEZE Signal", message='{"ticker":"{{ticker}}","action":"SQUEEZE_DETECTED","close":"{{close}}","volume":"{{volume}}","system":"SML_FTD_Hunter","timeframe":"{{interval}}","secret_key":"sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802"}')

// Dynamic inline alerts (fire on every bar match)
if longCond
    alert('{"ticker":"' + syminfo.ticker + '","action":"EXECUTE_LONG","close":"' + str.tostring(close) + '","volume":"' + str.tostring(volume) + '","system":"SML_Leviathan","timeframe":"' + timeframe.period + '","secret_key":"sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802"}', alert.freq_once_per_bar_close)

if shortCond
    alert('{"ticker":"' + syminfo.ticker + '","action":"EXECUTE_SHORT","close":"' + str.tostring(close) + '","volume":"' + str.tostring(volume) + '","system":"SML_Leviathan","timeframe":"' + timeframe.period + '","secret_key":"sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802"}', alert.freq_once_per_bar_close)

if squeezeCond
    alert('{"ticker":"' + syminfo.ticker + '","action":"SQUEEZE_DETECTED","close":"' + str.tostring(close) + '","volume":"' + str.tostring(volume) + '","system":"SML_FTD_Hunter","timeframe":"' + timeframe.period + '","secret_key":"sml-ingest-3e25f14cae28c8382940b0aa8f27d51283388802"}', alert.freq_once_per_bar_close)
