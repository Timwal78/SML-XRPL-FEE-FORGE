# =============================================================================
# x402 Gateway — environment configuration
# =============================================================================
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080
REDIS_URL=redis://localhost:6379
RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# x402 Payment
# -----------------------------------------------------------------------------
# EVM wallet address that receives USDC on Base network
MERCHANT_WALLET_ADDRESS=0xYOUR_WALLET_HERE

# Price in USDC micro-units (6 decimals): 500000 = $0.50
PAYMENT_AMOUNT_USDC_DROPS=500000

# x402 facilitator endpoint (default: https://x402.org/facilitator)
X402_FACILITATOR_URL=https://x402.org/facilitator

# -----------------------------------------------------------------------------
# BYOK Inference Engine
# -----------------------------------------------------------------------------
# Set at least one of these. BYOK_PROVIDER=auto selects whichever is available.
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# auto | anthropic | openai
BYOK_PROVIDER=auto

# -----------------------------------------------------------------------------
# XRPL Ghost Layer (Notary)
# -----------------------------------------------------------------------------
# XRPL wallet that submits trust/reputation memos after each settlement
XRPL_NOTARY_WALLET_ADDRESS=rYOUR_XRPL_ADDRESS
XRPL_NOTARY_WALLET_SEED=sYOUR_FAMILY_SEED

# testnet | mainnet
XRPL_NETWORK=testnet

# Override RPC endpoint (auto-selected from XRPL_NETWORK if blank)
XRPL_RPC_URL=
